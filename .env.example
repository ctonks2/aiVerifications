# API Keys and Configuration
# Copy this file to .env and fill in your actual keys
# Never commit .env to git!

# Anthropic Claude API (critical analysis, legal reasoning)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# COST OPTIMIZATION: Local Ollama LLM
# Set up Ollama at https://ollama.ai to run models locally for free
# This saves ~$0.01 per Stage 2 analysis
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Hybrid LLM Strategy (mixes local Ollama + Claude for cost savings)
USE_HYBRID_LLM=true
PREFER_OLLAMA=true
FALLBACK_TO_CLAUDE=true
TRACK_COSTS=true

# Optional: Alternative AI services
# OPENAI_API_KEY=your_openai_api_key_here
# YOTI_API_KEY=your_yoti_key_here
# VERIFF_API_KEY=your_veriff_key_here

# Logging and debugging
DEBUG=false
LOG_LEVEL=info
