{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Run checker",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["tsx", "src/index.ts"],
      "console": "integratedTerminal",
      "env": { "HEADED": "0" }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Run checker (headed)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["tsx", "src/index.ts"],
      "console": "integratedTerminal",
      "env": { "HEADED": "1" }
    }
  ]
}
