{
  "name": "ai-verifications",
  "version": "1.0.0",
  "description": "Age Verifier using headless browser automation",
  "main": "dist/index.js",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "test": "tsx src/test.ts",
    "demo": "tsx src/demo.ts",
    "api": "tsx api.ts",
    "ui": "cd ui && npm run dev",
    "dev:all": "concurrently \"npm run api\" \"npm run ui\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "concurrently": "^8.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.28.0",
    "dotenv": "^16.6.1",
    "playwright": "^1.40.0",
    "express": "^4.18.0",
    "cors": "^2.8.5"
  }
}
